    "next": "^15.3.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pizzip": "^3.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
