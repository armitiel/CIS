{
  "name": "cis-app",
  "version": "0.1.0",
  "private": true,
  "description": "Aplikacja do obsługi Centrum Integracji Społecznej w Świebodzinie — Stowarzyszenie Pomost",
  "scripts": {
    "dev": "next dev",
    "build": "npm run check && next build",
    "start": "next start",
    "lint": "next lint",
